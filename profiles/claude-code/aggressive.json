{
  "name": "aggressive",
  "extends": "balanced",
  "description": "Tighter output caps and a PreToolUse bash-guard hook (observe-only in v0.1). For cost-sensitive sessions.",
  "assets": ["hooks/bash-guard"],
  "settings": {
    "env": {
      "BASH_MAX_OUTPUT_LENGTH": "8000",
      "MAX_MCP_OUTPUT_TOKENS": "6000"
    },
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "{{configDir}}/hooks/leanrig-bash-guard.sh"
            }
          ]
        }
      ]
    }
  }
}
