{
  "name": "leanrig",
  "version": "0.2.0",
  "description": "Reduce Claude Code token usage and API costs: audit waste, install safe reversible cost-saving profiles, and manage token-saving tools like ccusage, caveman, and squeez — with full rollback",
  "keywords": [
    "claude-code",
    "claude",
    "token-usage",
    "token-optimization",
    "cost-optimization",
    "ai-coding-agent",
    "ccusage",
    "rate-limits",
    "context-window",
    "anthropic",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuanyongxigua/lean-rig.git"
  },
  "homepage": "https://github.com/zhuanyongxigua/lean-rig#readme",
  "bugs": {
    "url": "https://github.com/zhuanyongxigua/lean-rig/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "leanrig": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "profiles",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "node --loader ts-node/esm src/index.ts",
    "e2e": "bash scripts/e2e.sh"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
