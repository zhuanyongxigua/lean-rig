{
  "name": "leanrig",
  "version": "0.1.0",
  "description": "Install safe, reversible cost-control profiles into AI coding agent harnesses",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "leanrig": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "profiles",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
